# HealingTech Initiative — Production Environment Variables
# Copy to .env.local for local development
# Add the same variables in Vercel → Settings → Environment Variables

# Canonical site URL (used for SEO, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=https://healingtechinitiative.org

# Technology partner website
NEXT_PUBLIC_LABS_URL=https://healingtechlabs.com

# Optional: powers the Smart Assistant with OpenAI (gpt-4o-mini)
# Without this, the assistant uses built-in trained responses
OPENAI_API_KEY=sk-your-key-here

# Optional: Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional: Google Search Console HTML tag verification code
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
